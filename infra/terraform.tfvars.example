# Copy to terraform.tfvars and fill in your Supabase values.
# Never commit terraform.tfvars — it is in .gitignore.
# All other variables have sensible defaults (see variables.tf).

supabase_url      = "https://YOUR_PROJECT_REF.supabase.co"
supabase_anon_key = "YOUR_SUPABASE_ANON_KEY"

# Optional: custom domain for the React frontend via CloudFront.
# Requires an ACM certificate in us-east-1. Omit to use the auto-assigned
# cloudfront.net domain printed by 'terraform output cloudfront_domain'.
#
# cloudfront_certificate_arn = "arn:aws:acm:us-east-1:ACCOUNT_ID:certificate/CERT_ID"
# cloudfront_domain          = "app.yourdomain.com"
