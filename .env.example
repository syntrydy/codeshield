# ============================================================
# CodeShield — local development environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is gitignored.
# Production secrets live in AWS Secrets Manager, not here.
# ============================================================

# ------------------------------------------------------------
# Supabase
# ------------------------------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=<publishable-key>
SUPABASE_SECRET_KEY=<secret-key>
# JWT verification now uses JWKS from <supabase_url>/auth/v1/.well-known/jwks.json — no secret needed.

# ------------------------------------------------------------
# GitHub App
# ------------------------------------------------------------
GITHUB_APP_ID=<app-id>
GITHUB_APP_SLUG=<app-slug>
# In production the private key is fetched from Secrets Manager at boot.
# Locally, point to your downloaded .pem file path (outside this repo).
GITHUB_PRIVATE_KEY_PATH=/path/to/your/app.pem
GITHUB_WEBHOOK_SECRET=<webhook-secret>

# ------------------------------------------------------------
# Anthropic
# ------------------------------------------------------------
ANTHROPIC_API_KEY=<anthropic-api-key>

# ------------------------------------------------------------
# LangSmith
# ------------------------------------------------------------
LANGSMITH_API_KEY=<langsmith-api-key>
LANGSMITH_ENDPOINT=https://api.smith.langchain.com  # use https://eu.api.smith.langchain.com for EU region
LANGSMITH_PROJECT=code-review-dev
LANGCHAIN_TRACING_V2=true

# ------------------------------------------------------------
# Redis (Celery broker + idempotency cache)
# ------------------------------------------------------------
# When running via docker compose use the service name; for local-only dev use localhost
REDIS_URL=redis://redis:6379/0

# ------------------------------------------------------------
# API service
# ------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO

# ------------------------------------------------------------
# AWS (only needed locally if testing S3 artifact upload)
# ------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=<key-id>
AWS_SECRET_ACCESS_KEY=<secret>
S3_ARTIFACTS_BUCKET=code-review-artifacts-dev

# ------------------------------------------------------------
# Frontend (injected at Vite build time via VITE_ prefix)
# ------------------------------------------------------------
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<publishable-key>
VITE_API_BASE_URL=http://localhost:8000
VITE_GITHUB_APP_SLUG=<app-slug>
